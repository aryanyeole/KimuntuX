{
  "info": {
    "name": "KimuX — ClickBank Integration",
    "description": "Phase 2 endpoints: account connect/sync (tenant credentials).\n\nPre-requisites:\n1. Set {{base_url}} = http://localhost:8000\n2. Log in via POST /api/v1/auth/token and set {{token}} = access_token\n3. Set {{tenant_id}} = your tenant UUID (from GET /api/v1/auth/me/tenant)\n\nCredential tier:\n- Tenant: per-user developer key stored Fernet-encrypted in integration_credentials table",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "token",    "value": "" },
    { "key": "tenant_id", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/auth/token",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "username", "value": "your@email.com" },
                { "key": "password", "value": "yourpassword" }
              ]
            }
          }
        },
        {
          "name": "Get My Tenant",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/auth/me/tenant"
          }
        }
      ]
    },
    {
      "name": "Account (Tenant Credentials)",
      "description": "Per-tenant ClickBank account connection. Uses the tenant's own developer key, encrypted with Fernet and stored in integration_credentials table. Lets tenants sync their own products and see account-specific data.",
      "item": [
        {
          "name": "Connect Account",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/crm/integrations/clickbank/account/connect",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID",  "value": "{{tenant_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"developer_key\": \"YOUR_CLICKBANK_DEVELOPER_KEY\",\n  \"account_nickname\": \"My Vendor Account\"\n}"
            }
          },
          "response": [
            {
              "name": "200 Connected",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"connected\": true,\n  \"account_nickname\": \"My Vendor Account\",\n  \"last_sync_at\": null,\n  \"offer_count\": 0,\n  \"account_summary\": {}\n}"
            },
            {
              "name": "400 — Invalid key",
              "status": "Bad Request",
              "code": 400,
              "body": "{ \"detail\": \"Invalid ClickBank credentials: ClickBank rejected credentials (HTTP 401)\" }"
            },
            {
              "name": "502 — ClickBank unreachable",
              "status": "Bad Gateway",
              "code": 502,
              "body": "{ \"detail\": \"Could not reach ClickBank to verify credentials: ...\" }"
            }
          ]
        },
        {
          "name": "Account Status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/crm/integrations/clickbank/account/status",
            "header": [
              { "key": "X-Tenant-ID", "value": "{{tenant_id}}" }
            ]
          },
          "response": [
            {
              "name": "200 Connected",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"connected\": true,\n  \"account_nickname\": \"My Vendor Account\",\n  \"last_sync_at\": \"2026-04-17T11:00:00Z\",\n  \"offer_count\": 3,\n  \"account_summary\": {}\n}"
            },
            {
              "name": "200 Not connected",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"connected\": false,\n  \"offer_count\": 0\n}"
            }
          ]
        },
        {
          "name": "Sync Account Offers",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/crm/integrations/clickbank/account/sync",
            "header": [
              { "key": "X-Tenant-ID", "value": "{{tenant_id}}" }
            ]
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"synced\": 3,\n  \"created\": 3,\n  \"updated\": 0,\n  \"last_synced_at\": \"2026-04-17T11:00:00Z\"\n}"
            },
            {
              "name": "400 — Not connected",
              "status": "Bad Request",
              "code": 400,
              "body": "{ \"detail\": \"No ClickBank account connected. Connect your account in Settings first.\" }"
            }
          ]
        },
        {
          "name": "Disconnect Account",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/crm/integrations/clickbank/account/disconnect",
            "header": [
              { "key": "X-Tenant-ID", "value": "{{tenant_id}}" }
            ]
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{ \"detail\": \"ClickBank account disconnected. Synced offers are retained.\" }"
            }
          ]
        }
      ]
    }
  ]
}
