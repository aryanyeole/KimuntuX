# ═══════════════════════════════════════════════════════════════════════════
# ALWAYS KEEP THESE FILES
# ═══════════════════════════════════════════════════════════════════════════
#
# Use ! to explicitly include files that would otherwise be ignored
#
# Examples:
# !deployments/.gitkeep
# !.vscode/settings.json
#
# ═══════════════════════════════════════════════════════════════════════════

# Keep example files
!.env.example
!config.example.js

# Keep empty directories
!.gitkeep


# ═══════════════════════════════════════════════════════════════════════════
# VERIFICATION CHECKLIST
# ═══════════════════════════════════════════════════════════════════════════
#
# Before committing, verify:
#   ✅ No .env file in staging area: git status | grep .env
#   ✅ No private keys: git diff | grep -i "private"
#   ✅ No API keys: git diff | grep -i "api.*key"
#   ✅ No wallet addresses with funds: git diff | grep "0x[a-fA-F0-9]\{40\}"
#   ✅ Run: git secrets --scan (if installed)
#
# ═══════════════════════════════════════════════════════════════════════════
