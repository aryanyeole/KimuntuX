# ═══════════════════════════════════════════════════════════════════════════
# KIMUNTUX BLOCKCHAIN INTEGRATION - ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════════════
#
# ⚠️  SECURITY WARNING:
#   - NEVER commit your actual .env file to git
#   - NEVER share private keys with anyone
#   - NEVER use mainnet private keys for testnet
#   - ALWAYS use separate wallets for testing and production
#
# SETUP INSTRUCTIONS:
#   1. Copy this file to .env: cp .env.example .env
#   2. Fill in your actual values (instructions below)
#   3. Verify .env is in .gitignore (it should be)
#   4. NEVER commit .env to version control
#
# ═══════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════
# BLOCKCHAIN RPC PROVIDERS
# ═══════════════════════════════════════════════════════════════════════════
#
# RPC URLs connect your app to blockchain networks.
# You need an RPC provider for deploying and interacting with contracts.
#
# RECOMMENDED PROVIDERS:
#   - Alchemy (https://www.alchemy.com) - Best for Ethereum, Polygon
#   - Infura (https://www.infura.io) - Alternative for Ethereum
#   - QuickNode (https://www.quicknode.com) - Multi-chain support
#
# HOW TO GET AN API KEY:
#   1. Sign up at provider's website (Alchemy recommended)
#   2. Create a new app/project
#   3. Select the network (e.g., Ethereum Sepolia)
#   4. Copy the HTTPS URL (not WebSocket)
#   5. Paste it below, replacing YOUR_ALCHEMY_API_KEY
#
# SECURITY:
#   - RPC URLs with API keys should be kept private
#   - Free tier is sufficient for testing
#   - Rate limits apply (usually 300 req/sec for free tier)
#
# ═══════════════════════════════════════════════════════════════════════════

# Ethereum Sepolia Testnet (PRIMARY TESTNET - USE THIS FIRST)
# Format: https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Ethereum Mainnet (PRODUCTION - Use only after audit and testing)
# Format: https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Polygon Mainnet (RECOMMENDED FOR PRODUCTION - Lower gas fees)
# Format: https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Polygon Amoy Testnet (New Polygon testnet)
# Format: https://polygon-amoy.g.alchemy.com/v2/YOUR_API_KEY
AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# BSC Testnet (Optional - Binance Smart Chain testing)
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# BSC Mainnet (Optional - Binance Smart Chain production)
BSC_RPC_URL=https://bsc-dataseed1.binance.org


# ═══════════════════════════════════════════════════════════════════════════
# DEPLOYER WALLET PRIVATE KEYS
# ═══════════════════════════════════════════════════════════════════════════
#
# ⚠️  CRITICAL SECURITY INFORMATION:
#
# WHAT IS A PRIVATE KEY?
#   - A 64-character hexadecimal string (with or without 0x prefix)
#   - Gives COMPLETE CONTROL over the wallet
#   - If leaked, anyone can steal ALL your funds
#   - CANNOT be recovered if lost
#
# HOW TO GET YOUR PRIVATE KEY:
#   1. Open MetaMask
#   2. Click the three dots → Account details
#   3. Click "Show private key"
#   4. Enter your MetaMask password
#   5. Copy the private key (starts with 0x)
#   6. Paste it below
#
# SECURITY BEST PRACTICES:
#   ✅ DO:
#      - Use separate wallets for testnet and mainnet
#      - Create a new wallet specifically for deployment
#      - Keep private keys in password manager (1Password, LastPass)
#      - Use hardware wallet (Ledger, Trezor) for mainnet
#      - Regularly rotate keys
#      - Use multi-sig wallet for mainnet contract ownership
#
#   ❌ DON'T:
#      - Never commit private keys to git
#      - Never share via email, Slack, Discord
#      - Never use personal wallet for deployment
#      - Never reuse testnet keys for mainnet
#      - Never store in plaintext files (except .env with proper .gitignore)
#      - Never use the same key across multiple projects
#
# WHAT IF MY KEY IS COMPROMISED?
#   1. Immediately transfer all funds to a new wallet
#   2. Never use that key again
#   3. Transfer contract ownership if already deployed
#   4. Audit all recent transactions for suspicious activity
#
# TESTNET WALLET SETUP:
#   1. Create a NEW MetaMask wallet (dedicated for testnet)
#   2. Get Sepolia ETH from faucets:
#      - https://sepoliafaucet.com
#      - https://sepolia-faucet.pk910.de
#      - https://www.alchemy.com/faucets/ethereum-sepolia
#   3. You need ~0.1 ETH for deployment (it's free testnet ETH)
#
# ═══════════════════════════════════════════════════════════════════════════

# Testnet Private Key (for Sepolia, Amoy, BSC Testnet)
# Format: 0x1234567890abcdef... (64 hex characters after 0x)
# ⚠️  Use a DEDICATED testnet wallet - never use your main wallet!
PRIVATE_KEY=your_testnet_deployer_private_key_here

# Mainnet Private Key (for Ethereum, Polygon, BSC Mainnet)
# Format: 0x1234567890abcdef... (64 hex characters after 0x)
# ⚠️  EXTREME CAUTION: This controls real money!
# ⚠️  Use hardware wallet (Ledger/Trezor) for mainnet deployments
# ⚠️  Consider using multi-sig wallet (Gnosis Safe)
MAINNET_PRIVATE_KEY=your_mainnet_deployer_private_key_here


# ═══════════════════════════════════════════════════════════════════════════
# BLOCK EXPLORER API KEYS (For Contract Verification)
# ═══════════════════════════════════════════════════════════════════════════
#
# WHY VERIFY CONTRACTS?
#   - Users can read your contract source code
#   - Users can interact with contract via Etherscan UI
#   - Builds trust and transparency
#   - Required for serious projects
#   - Free and takes 2 minutes
#
# HOW TO GET ETHERSCAN API KEY:
#   1. Go to https://etherscan.io/myapikey
#   2. Sign up for free account
#   3. Click "Add" to create new API key
#   4. Name it "KimuntuX Development"
#   5. Copy the API key
#   6. Paste it below
#
# VERIFICATION PROCESS:
#   1. Deploy contract: npm run deploy:sepolia
#   2. Verify contract: npm run verify:sepolia
#   3. View on Etherscan: https://sepolia.etherscan.io
#
# SECURITY:
#   - API keys are semi-sensitive (rate limits apply)
#   - Free tier: 5 calls/second, 100,000 calls/day
#   - Don't share publicly but not as critical as private keys
#
# ═══════════════════════════════════════════════════════════════════════════

# Etherscan API Key (for Ethereum mainnet and testnets)
# Get from: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# PolygonScan API Key (for Polygon mainnet and testnets)
# Get from: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# BscScan API Key (for BSC mainnet and testnet)
# Get from: https://bscscan.com/myapikey
BSCSCAN_API_KEY=your_bscscan_api_key_here


# ═══════════════════════════════════════════════════════════════════════════
# GAS REPORTING AND ANALYTICS
# ═══════════════════════════════════════════════════════════════════════════
#
# Gas reporting helps optimize contract costs
#
# SETUP:
#   1. Set REPORT_GAS=true to enable
#   2. Run tests: npx hardhat test
#   3. View report: gas-report.txt
#   4. Optimize high-gas functions
#
# COINMARKETCAP API (OPTIONAL):
#   - Shows gas costs in USD
#   - Get free API key: https://coinmarketcap.com/api/
#   - Not required for basic gas reporting
#
# ═══════════════════════════════════════════════════════════════════════════

# Enable gas reporting during tests (true/false)
REPORT_GAS=false

# CoinMarketCap API key for USD cost estimates (optional)
# Get from: https://coinmarketcap.com/api/
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here


# ═══════════════════════════════════════════════════════════════════════════
# CONTRACT DEPLOYMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
#
# These values are used as constructor arguments during deployment
# Adjust based on your requirements
#
# UNITS:
#   - All amounts are in WEI (1 ETH = 1,000,000,000,000,000,000 WEI)
#   - Use https://eth-converter.com for conversions
#
# EXAMPLES:
#   0.01 ETH = 10000000000000000 WEI
#   0.1 ETH  = 100000000000000000 WEI
#   1 ETH    = 1000000000000000000 WEI
#
# ═══════════════════════════════════════════════════════════════════════════

# KimuntuXWallet: Minimum withdrawal amount
# Default: 10000000000000000 (0.01 ETH)
# Recommendation: Keep at 0.01 ETH to prevent dust withdrawals
MINIMUM_WITHDRAWAL_AMOUNT=10000000000000000

# KimuntuXCommissionSystem: Minimum payout threshold
# Default: 10000000000000000 (0.01 ETH)
# Recommendation: Balance between frequent payouts and gas costs
MINIMUM_PAYOUT=10000000000000000

# KimuntuXCommissionSystem: Platform fee rate (basis points)
# Default: 300 (3.00%)
# Format: 100 = 1%, 300 = 3%, 500 = 5%
# Recommendation: 2-5% is standard for platforms
PLATFORM_FEE_RATE=300

# PaymentEscrow: Escrow fee rate (basis points)
# Default: 200 (2.00%)
# Format: 100 = 1%, 200 = 2%, 500 = 5%
# Recommendation: 1-3% is standard for escrow services
ESCROW_FEE_RATE=200


# ═══════════════════════════════════════════════════════════════════════════
# ADVANCED CONFIGURATION (OPTIONAL)
# ═══════════════════════════════════════════════════════════════════════════

# Node Environment (development/production)
NODE_ENV=development

# Enable debug logging
DEBUG=false

# Contract size limits (uncomment to enable warnings)
# CONTRACT_SIZE_LIMIT=24576

# Deployment gas limit (uncomment to set custom limit)
# GAS_LIMIT=6000000


# ═══════════════════════════════════════════════════════════════════════════
# QUICK START CHECKLIST
# ═══════════════════════════════════════════════════════════════════════════
#
# For Sepolia Testnet Deployment (Start Here):
#   ✅ 1. Create new MetaMask wallet for testing
#   ✅ 2. Get Sepolia ETH from faucet (~0.1 ETH)
#   ✅ 3. Get Alchemy API key (Sepolia network)
#   ✅ 4. Get Etherscan API key
#   ✅ 5. Copy private key from MetaMask
#   ✅ 6. Fill in SEPOLIA_RPC_URL above
#   ✅ 7. Fill in PRIVATE_KEY above
#   ✅ 8. Fill in ETHERSCAN_API_KEY above
#   ✅ 9. Run: npm install
#   ✅ 10. Run: npm run compile
#   ✅ 11. Run: npm run deploy:sepolia
#   ✅ 12. Run: npm run verify:sepolia
#
# For Mainnet Deployment (ONLY AFTER THOROUGH TESTING):
#   ✅ 1. Complete 100+ test transactions on Sepolia
#   ✅ 2. Get professional security audit ($15k-30k)
#   ✅ 3. Fix all audit findings
#   ✅ 4. Create new wallet for mainnet (hardware wallet recommended)
#   ✅ 5. Fund wallet with 0.5-1 ETH for deployment
#   ✅ 6. Setup multi-sig wallet (Gnosis Safe)
#   ✅ 7. Fill in MAINNET_RPC_URL
#   ✅ 8. Fill in MAINNET_PRIVATE_KEY (from hardware wallet)
#   ✅ 9. Triple-check all configuration
#   ✅ 10. Deploy to mainnet (NO UNDO!)
#   ✅ 11. Transfer ownership to multi-sig
#   ✅ 12. Verify contracts on Etherscan
#   ✅ 13. Setup monitoring (OpenZeppelin Defender)
#
# ═══════════════════════════════════════════════════════════════════════════
