# Blockchain RPC URLs
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Private Keys (NEVER commit actual keys!)
PRIVATE_KEY=your_deployer_private_key_here
MAINNET_PRIVATE_KEY=your_mainnet_private_key_here

# Etherscan API Keys (for contract verification)
ETHERSCAN_API_KEY=your_etherscan_api_key_here
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
BSCSCAN_API_KEY=your_bscscan_api_key_here

# Gas Reporter
REPORT_GAS=false
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here

# Contract Configuration
MINIMUM_WITHDRAWAL_AMOUNT=10000000000000000
MINIMUM_PAYOUT=10000000000000000
PLATFORM_FEE_RATE=300
ESCROW_FEE_RATE=200
