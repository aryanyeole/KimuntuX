APP_NAME=KimuX Backend
APP_ENV=development
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:YOUR_DB_PASSWORD@YOUR_RDS_ENDPOINT:5432/kimuntu
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate with: python -m app.scripts.generate_fernet_key
KIMUX_FERNET_KEY=

# ── ClickBank platform credential (KimuX's own key — post-Aug 2023 single-key auth) ──
# Authorization header: Authorization: <developer_key>
# Used to sync the public marketplace for all tenants.
# Tenant-specific keys are stored encrypted in the integration_credentials table.
CLICKBANK_DEVELOPER_KEY=

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MOCK_MODE=true
# ── DataForSEO (optional keyword enrichment) ─────────────────────────────────
DATAFORSEO_LOGIN=your_dataforseo_email
DATAFORSEO_PASSWORD=your_dataforseo_password

// set to true to test fake campaign data
CAMPAIGN_TEST_MODE=false
