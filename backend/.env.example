# ─────────────────────────────────────────────────────────────────────────────
# KimuntuX Backend - Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=KimuntuX Backend
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
API_V1_PREFIX=/api/v1

# ─── Auth / JWT (CRM backend) ─────────────────────────────────────────────────
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── Blockchain: RPC Providers ────────────────────────────────────────────────
# Get a free key at https://dashboard.alchemy.com
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE

# Optional: fallback provider (e.g. Infura)
SEPOLIA_RPC_FALLBACK=https://sepolia.infura.io/v3/YOUR_INFURA_KEY_HERE

# ─── Blockchain: Platform Wallet ──────────────────────────────────────────────
# The platform wallet that pays gas for all on-chain operations.
# Export from MetaMask: Account Details → Export Private Key
# DO NOT include the 0x prefix.
PLATFORM_PRIVATE_KEY=your_64_character_hex_private_key_here

# Platform wallet address (must match the private key above)
PLATFORM_ADDRESS=0xYourPlatformWalletAddress

# ─── Blockchain: Contract Addresses ───────────────────────────────────────────
# These are set after deploying contracts with: npm run deploy:sepolia
COMMISSION_CONTRACT_ADDRESS=0xYourCommissionContractAddress
WALLET_CONTRACT_ADDRESS=0xYourWalletContractAddress
ESCROW_CONTRACT_ADDRESS=0xYourEscrowContractAddress

# ─── Blockchain: Gas Configuration ────────────────────────────────────────────
GAS_LIMIT_BUFFER=1.2
MAX_GAS_PRICE_GWEI=100
TRANSACTION_TIMEOUT_SECONDS=180

# ─── Database: PostgreSQL ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/kimuntux_db

# ─── Database: Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=30

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
