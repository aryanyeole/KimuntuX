APP_NAME=KimuX Backend
APP_ENV=development
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:YOUR_DB_PASSWORD@YOUR_RDS_ENDPOINT:5432/kimuntu
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000

# ── Encryption ────────────────────────────────────────────────────────────────
# Required. Generate with: python -m app.scripts.generate_fernet_key
KIMUX_FERNET_KEY=

# ── Reply address tokens ──────────────────────────────────────────────────────
# Required. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
KIMUX_REPLY_TOKEN_SECRET=

# ── SendGrid (Phase 3) ────────────────────────────────────────────────────────
SENDGRID_API_KEY=
# ECDSA key from Mail Settings → Event Webhook → Signature. Required if SENDGRID_API_KEY is set.
SENDGRID_EVENT_WEBHOOK_PUBLIC_KEY=
# Toggle signature verification on the Inbound Parse webhook (true in prod).
SENDGRID_INBOUND_VERIFY=false
SENDGRID_INBOUND_PUBLIC_KEY=
DEFAULT_SENDER_EMAIL=
DEFAULT_SENDER_NAME=KimuX
REPLY_DOMAIN=reply.kimux.io
# Required. Generate with: cd backend && python -m app.scripts.generate_fernet_key
KIMUX_FERNET_KEY=

# Optional startup admin defaults
BOOTSTRAP_ADMIN_EMAIL=yannick@example.com
BOOTSTRAP_ADMIN_PASSWORD=Capstone@123
BOOTSTRAP_ADMIN_FULL_NAME=Yannick

# ClickBank platform credential
CLICKBANK_DEVELOPER_KEY=

# AI
GEMINI_API_KEY=
GEMINI_MOCK_MODE=true

// set to true to test fake campaign data
CAMPAIGN_TEST_MODE=false
# Optional DataForSEO enrichment
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Optional blockchain settings - CRM still works when these are unset
# For local Hardhat: SEPOLIA_RPC_URL=http://127.0.0.1:8545 and EXPECTED_CHAIN_ID=31337
SEPOLIA_RPC_URL=
SEPOLIA_RPC_FALLBACK=
EXPECTED_CHAIN_ID=11155111
PLATFORM_PRIVATE_KEY=
PLATFORM_ADDRESS=
COMMISSION_CONTRACT_ADDRESS=
WALLET_CONTRACT_ADDRESS=
ESCROW_CONTRACT_ADDRESS=
GAS_LIMIT_BUFFER=1.2
MAX_GAS_PRICE_GWEI=100
TRANSACTION_TIMEOUT_SECONDS=180
