APP_NAME=KimuntuX Backend
APP_ENV=development
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:YOUR_DB_PASSWORD@YOUR_RDS_ENDPOINT:5432/kimuntu
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000
# Optional: override default bootstrap admin (yannick@example.com / Capstone@123)
# BOOTSTRAP_ADMIN_EMAIL=
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_ADMIN_FULL_NAME=
