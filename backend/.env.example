APP_NAME=KimuntuX Backend
APP_ENV=development
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:YOUR_DB_PASSWORD@YOUR_RDS_ENDPOINT:5432/kimuntu
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000

# ── Encryption ────────────────────────────────────────────────────────────────
# Required. Generate with: python -m app.scripts.generate_fernet_key
KIMUX_FERNET_KEY=

# ── Reply address tokens ──────────────────────────────────────────────────────
# Required. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
KIMUX_REPLY_TOKEN_SECRET=

# ── SendGrid (Phase 3) ────────────────────────────────────────────────────────
SENDGRID_API_KEY=
# ECDSA key from Mail Settings → Event Webhook → Signature. Required if SENDGRID_API_KEY is set.
SENDGRID_EVENT_WEBHOOK_PUBLIC_KEY=
# Toggle signature verification on the Inbound Parse webhook (true in prod).
SENDGRID_INBOUND_VERIFY=false
SENDGRID_INBOUND_PUBLIC_KEY=
DEFAULT_SENDER_EMAIL=
DEFAULT_SENDER_NAME=KimuX
REPLY_DOMAIN=reply.kimux.io

# ── AI ────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

